# Copy this file to .env for local development. DO NOT commit .env.
#
# Vite exposes only variables prefixed with VITE_ to client-side code.
# Server-only secrets (DB passwords, private keys) must NOT use the VITE_ prefix.

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------

# Base URL for API calls made from the browser.
# Leave empty so Axios uses relative URLs proxied by Vite (avoids CORS in local dev).
# Set to an absolute URL only when running against a deployed API or in CI/CD.
VITE_API_BASE_URL=

# Where the Vite dev server forwards /api requests (server-to-server, no CORS).
# Change to match whichever backend you are developing against.
VITE_API_PROXY_TARGET=http://localhost:8080

# ---------------------------------------------------------------------------
# Auth (example — adapt to your auth strategy)
# ---------------------------------------------------------------------------

VITE_AUTH_DOMAIN=
VITE_AUTH_CLIENT_ID=

# ---------------------------------------------------------------------------
# Feature flags (example)
# ---------------------------------------------------------------------------

VITE_FEATURE_DARK_MODE=true
VITE_FEATURE_ANALYTICS=false
